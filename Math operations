import math
n=int(input("Enter a number:"))
print("Square root",math.sqrt(n))
pi=math.pi
print(pi)
deg=int(input("Enter a degree:"))
rad=math.radians(deg)
print("Radian",rad)
angle=math.radians(30)
sine=math.sin(angle)
cose=math.cos(angle)
tan=math.tan(angle)
print("Sine",sine)
print("Cos",cose)
print("Tan",tan)
expo=math.exp(n)
print("EXponential of e^4",expo)
log=math.log(10,10)
print("Log of ",log)
fact=math.factorial(n)
print("Factorial",fact)
